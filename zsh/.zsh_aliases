alias i="ipython"
alias h="cd ~"
alias vim="nvim"

# give me more info with ls
alias ls="ls -a --color"

# aliases for editting and sourcing configuration files
alias vz="vim ~/.zshrc"
alias vt="vim ~/.tmux.conf"
alias va="vim ~/.zsh_aliases"
alias vv="cd ~/.config/nvim/ && vim ~/.config/nvim/lua/custom/plugins.lua"
alias sz="source ~/.zshrc"
alias st="tmux source ~/.tmux.conf"

# pull up cheatsheet
alias cs="vim ~/dotfiles/cheatsheet.txt"

# bookmarks
alias insta="cd ~/Documents/Programming\ Projects/Python/unfollow-bot"
